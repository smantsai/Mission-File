<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main Tree">
  <BehaviorTree ID="Bins">
    <Sequence>
      <DriveToWorldWaypointSeeking world_waypoint=""
                                   waypoint_mask=""
                                   object=""
                                   confidence=""
                                   _description="Find the orange marker pointing to bins task."/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Manny follows the orange marker to the Bins Task."/>
      <Repeat num_cycles="2">
        <Sequence>
          <DriveToWorldWaypointSeeking world_waypoint=""
                                       waypoint_mask=""
                                       object=""
                                       confidence=""
                                       _description="Drive and find a bin"/>
          <TrackObjectWaypoint tracking_position=""
                               waypoint_mask=""
                               object=""
                               tolerance=""
                               hold_time=""
                               _description="Manny positions itself directly over bin."/>
          <Idle _description="Send command to drop the marker."/>
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Gate Task">
    <Sequence>
      <DriveToWorldWaypoint world_waypoint=""
                            waypoint_mask=""
                            tolerance=""
                            hold_time=""
                            _description="Submerge Manny (go from surface to starting depth)"/>
      <DriveToWorldWaypointSeeking world_waypoint=""
                                   waypoint_mask=""
                                   object=""
                                   confidence=""
                                   _description="Manny drives to the starting position (premeasured beforehand) and locate the gate. Also store the gate coordinates for Return Gate Task."/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Manny orients itself to the gate."/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Find the side chosen (Search &amp; Rescue / Survey &amp; Repair) on the gate and orient itself in front of it. Store the side chosen."/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Manny drives through the located gate."/>
      <DistanceTrick trick=""
                     trick_end_body_waypoint=""
                     waypoint_mask=""
                     tolerance=""
                     hold_time=""
                     _description="Optional, distance trick for points. Do while driving through the gate. If we do distance trick, don&apos;t do previous step."/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Main Tree">
    <Sequence>
      <SubTree ID="Gate Task"/>
      <SubTree ID="Slalom"/>
      <SubTree ID="Bins"/>
      <SubTree ID="Octagon"/>
      <SubTree ID="Return to Gate"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Octagon">
    <Repeat num_cycles="2"
            _description="We need to repeat the action of finding the next item, grabbing it, surfacing with it, and then dropping it in the basket. However, it is unclear whether doing a repeat will suffice when we change the object that needs to be identified.">
      <Sequence>
        <DriveToWorldWaypointSeeking world_waypoint=""
                                     waypoint_mask=""
                                     object=""
                                     confidence=""
                                     _description="1. Manny locates the object on the supply table while driving to center&#10;2. We will measure to know how to get to the center&#10;    1. premeasured distance"/>
        <TrackObjectWaypoint tracking_position=""
                             waypoint_mask=""
                             object=""
                             tolerance=""
                             hold_time=""
                             _description="Manny moves to be above the object on the supply table"/>
        <Idle _description="Grab Item"/>
        <DriveToWorldWaypoint world_waypoint=""
                              waypoint_mask=""
                              tolerance=""
                              hold_time=""
                              _description="Manny surfaces with the item"/>
        <TrackObjectWaypoint tracking_position=""
                             waypoint_mask=""
                             object=""
                             tolerance=""
                             hold_time=""
                             _description="Position directly over the center of the basket"/>
        <Idle _description="Drop item into basket"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>

  <BehaviorTree ID="Return to Gate">
    <Sequence>
      <DriveToWorldWaypointSeeking world_waypoint=""
                                   waypoint_mask=""
                                   object=""
                                   confidence=""
                                   _description="Manny drives to approximately where the gate is. The coordinates should have been recorded and stored during Gate Task."/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Position Manny facing the gate at gate."/>
      <DriveToWorldWaypoint world_waypoint=""
                            waypoint_mask=""
                            tolerance=""
                            hold_time=""
                            _description="Drive through gate back to start."/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Slalom">
    <Sequence>
      <DriveToWorldWaypointSeeking world_waypoint=""
                                   waypoint_mask=""
                                   object=""
                                   confidence=""
                                   _description="Find the orange path marker pointing to slalom"/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""
                           _description="Follow the orange path marker to slalom"/>
      <Repeat num_cycles="3"
              _description="3 sets of pipes">
        <Sequence>
          <DriveToWorldWaypointSeeking world_waypoint=""
                                       waypoint_mask=""
                                       object=""
                                       confidence=""
                                       _description="Manny drives forward while looking for PVC pipes"/>
          <TrackObjectWaypoint tracking_position=""
                               waypoint_mask=""
                               object=""
                               tolerance=""
                               hold_time=""
                               _description="Manny drives forward X meters from the pipes."/>
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="DistanceTrick">
      <input_port name="trick"
                  type="string">Maneuver identification string</input_port>
      <input_port name="trick_end_body_waypoint"
                  type="std::vector&lt;float&gt;">Target position relative to start (FRD frame)</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">States to control upon arrival</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">Arrival error margin</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain at end position</input_port>
    </Action>
    <Action ID="DriveToWorldWaypoint">
      <input_port name="world_waypoint"
                  type="std::vector&lt;float&gt;">[6x1] Target position and orientation in world frame</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Specifies which states the controller must prioritize</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">[6x1] Allowed error margin for arrival</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain within tolerance before returning SUCCESS</input_port>
    </Action>
    <Action ID="DriveToWorldWaypointSeeking">
      <input_port name="world_waypoint"
                  type="std::vector&lt;float&gt;">Target position/orientation during search</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Controlled vs discretionary states</input_port>
      <input_port name="object"
                  type="string">Identification string of the target object</input_port>
      <input_port name="confidence"
                  type="float">Threshold for successful object identification</input_port>
    </Action>
    <Action ID="Idle"/>
    <Action ID="TrackObjectWaypoint">
      <input_port name="tracking_position"
                  type="std::vector&lt;float&gt;">[6x1] Target vector/orientation relative to Object k Frame</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Controlled vs discretionary states</input_port>
      <input_port name="object"
                  type="string">ID string of the object to track</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">Allowed error margin relative to object</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain at relative waypoint</input_port>
    </Action>
  </TreeNodesModel>

</root>
