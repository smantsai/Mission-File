<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main Tree">
  <BehaviorTree ID="Bins">
    <AlwaysSuccess/>
  </BehaviorTree>

  <BehaviorTree ID="Gate Task">
    <Sequence>
      <DriveToWorldWaypoint world_waypoint=""
                            waypoint_mask=""
                            tolerance=""
                            hold_time=""/>
      <DriveToWorldWaypointSeeking world_waypoint=""
                                   waypoint_mask=""
                                   object=""
                                   confidence=""/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""/>
      <TrackObjectWaypoint tracking_position=""
                           waypoint_mask=""
                           object=""
                           tolerance=""
                           hold_time=""/>
      <DistanceTrick trick=""
                     trick_end_body_waypoint=""
                     waypoint_mask=""
                     tolerance=""
                     hold_time=""/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Main Tree">
    <Sequence>
      <SubTree ID="Gate Task"/>
      <SubTree ID="Slalom"/>
      <SubTree ID="Bins"/>
      <SubTree ID="Octagon"/>
      <SubTree ID="Return to Gate"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Octagon">
    <AlwaysSuccess/>
  </BehaviorTree>

  <BehaviorTree ID="Return to Gate">
    <AlwaysSuccess/>
  </BehaviorTree>

  <BehaviorTree ID="Slalom">
    <AlwaysSuccess/>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="DistanceTrick">
      <input_port name="trick"
                  type="string">Maneuver identification string</input_port>
      <input_port name="trick_end_body_waypoint"
                  type="std::vector&lt;float&gt;">Target position relative to start (FRD frame)</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">States to control upon arrival</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">Arrival error margin</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain at end position</input_port>
    </Action>
    <Action ID="DriveToWorldWaypoint">
      <input_port name="world_waypoint"
                  type="std::vector&lt;float&gt;">[6x1] Target position and orientation in world frame</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Specifies which states the controller must prioritize</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">[6x1] Allowed error margin for arrival</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain within tolerance before returning SUCCESS</input_port>
    </Action>
    <Action ID="DriveToWorldWaypointSeeking">
      <input_port name="world_waypoint"
                  type="std::vector&lt;float&gt;">Target position/orientation during search</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Controlled vs discretionary states</input_port>
      <input_port name="object"
                  type="string">Identification string of the target object</input_port>
      <input_port name="confidence"
                  type="float">Threshold for successful object identification</input_port>
    </Action>
    <Action ID="TrackObjectWaypoint">
      <input_port name="tracking_position"
                  type="std::vector&lt;float&gt;">[6x1] Target vector/orientation relative to Object k Frame</input_port>
      <input_port name="waypoint_mask"
                  type="std::vector&lt;bool&gt;">[6x1] Controlled vs discretionary states</input_port>
      <input_port name="object"
                  type="string">ID string of the object to track</input_port>
      <input_port name="tolerance"
                  type="std::vector&lt;float&gt;">Allowed error margin relative to object</input_port>
      <input_port name="hold_time"
                  type="float">Time to remain at relative waypoint</input_port>
    </Action>
  </TreeNodesModel>

</root>
